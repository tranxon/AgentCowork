{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-v2-schema/main/schema.json",
  "productName": "AgentCowork",
  "version": "0.1.0",
  "identifier": "com.acowork.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run core:build && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "security": {
      "capabilities": [
        "main-capability"
      ],
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    },
    "windows": [
      {
        "title": "AgentCowork",
        "width": 1200,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "decorations": true,
        "transparent": true,
        "center": true,
        "visible": false,
        "shadow": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../examples/agent-packages": "agent-packages",
      "../../../assets/offline_providers.json": "offline_providers.json",
      "../../../assets/lsp_servers.json": "lsp_servers.json",
      "../../../assets/lsp_install": "lsp_install",
      "../../../core/acowork-embed/assets/embedding_models.json": "embedding_models.json",
      "bin/*": "./"
    }
  }
}
